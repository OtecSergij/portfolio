# Self-hosted Umami analytics (https://umami.is). Both variables must be set
# for the tracking script to render; leave them unset to ship no analytics at
# all — no placeholder, no request. Umami is cookieless, so enabling it does
# not require a consent banner.
#
# NEXT_PUBLIC_ values are inlined while pages are prerendered, so they must be
# present at build time: put them in .env.local for `next dev` / `next build`,
# or pass them as Docker build args (CI forwards repository variables of the
# same names).
NEXT_PUBLIC_UMAMI_SRC=https://umami.example.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
